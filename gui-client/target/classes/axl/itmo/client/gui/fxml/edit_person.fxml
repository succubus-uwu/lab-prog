<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="axl.itmo.client.gui.controller.EditPersonController"
      spacing="14" minWidth="420"
      style="-fx-padding: 24; -fx-background-color: #1e1e2e;">

    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #89b4fa;"/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="140" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>

        <Label fx:id="nameLabel"      GridPane.rowIndex="0"  GridPane.columnIndex="0"/>
        <TextField fx:id="nameField"  GridPane.rowIndex="0"  GridPane.columnIndex="1"/>

        <Label fx:id="coordXLabel"        GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="coordXField"    GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label fx:id="coordYLabel"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="coordYField"    GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label fx:id="heightLabel"        GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="heightField"    GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label fx:id="birthdayLabel"      GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <DatePicker fx:id="birthdayPicker" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label fx:id="passportLabel"      GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="passportField"  GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label fx:id="eyeColorLabel"      GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <ComboBox fx:id="eyeColorCombo"   GridPane.rowIndex="6" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label fx:id="locNameLabel"       GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="locNameField"   GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label fx:id="locXLabel"          GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextField fx:id="locXField"      GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        <Label fx:id="locYLabel"          GridPane.rowIndex="9" GridPane.columnIndex="0"/>
        <TextField fx:id="locYField"      GridPane.rowIndex="9" GridPane.columnIndex="1"/>

        <Label fx:id="locZLabel"          GridPane.rowIndex="10" GridPane.columnIndex="0"/>
        <TextField fx:id="locZField"      GridPane.rowIndex="10" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="validationLabel" id="errorLabel" wrapText="true" visible="false" maxWidth="380"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="cancelButton" onAction="#onCancel" styleClass="button"/>
        <Button fx:id="saveButton"   onAction="#onSave"   styleClass="button,accent" defaultButton="true"/>
    </HBox>
</VBox>
