<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="axl.itmo.client.gui.controller.PersonInfoController"
      spacing="14" minWidth="360"
      style="-fx-padding: 24; -fx-background-color: #1e1e2e;">

    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #89b4fa;"/>

    <GridPane hgap="14" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="130" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label fx:id="idKey"       GridPane.rowIndex="0"  GridPane.columnIndex="0"/>
        <Label fx:id="idVal"       GridPane.rowIndex="0"  GridPane.columnIndex="1"/>
        <Label fx:id="nameKey"     GridPane.rowIndex="1"  GridPane.columnIndex="0"/>
        <Label fx:id="nameVal"     GridPane.rowIndex="1"  GridPane.columnIndex="1"/>
        <Label fx:id="heightKey"   GridPane.rowIndex="2"  GridPane.columnIndex="0"/>
        <Label fx:id="heightVal"   GridPane.rowIndex="2"  GridPane.columnIndex="1"/>
        <Label fx:id="birthdayKey" GridPane.rowIndex="3"  GridPane.columnIndex="0"/>
        <Label fx:id="birthdayVal" GridPane.rowIndex="3"  GridPane.columnIndex="1"/>
        <Label fx:id="passportKey" GridPane.rowIndex="4"  GridPane.columnIndex="0"/>
        <Label fx:id="passportVal" GridPane.rowIndex="4"  GridPane.columnIndex="1"/>
        <Label fx:id="eyeKey"      GridPane.rowIndex="5"  GridPane.columnIndex="0"/>
        <Label fx:id="eyeVal"      GridPane.rowIndex="5"  GridPane.columnIndex="1"/>
        <Label fx:id="locKey"      GridPane.rowIndex="6"  GridPane.columnIndex="0"/>
        <Label fx:id="locVal"      GridPane.rowIndex="6"  GridPane.columnIndex="1" wrapText="true"/>
        <Label fx:id="createdKey"  GridPane.rowIndex="7"  GridPane.columnIndex="0"/>
        <Label fx:id="createdVal"  GridPane.rowIndex="7"  GridPane.columnIndex="1"/>
        <Label fx:id="ownerKey"    GridPane.rowIndex="8"  GridPane.columnIndex="0"/>
        <Label fx:id="ownerVal"    GridPane.rowIndex="8"  GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="editButton"   onAction="#onEdit"   styleClass="button,accent"/>
        <Button fx:id="deleteButton" onAction="#onDelete" styleClass="button,danger"/>
        <Button fx:id="closeButton"  onAction="#onClose"  styleClass="button"/>
    </HBox>
</VBox>
